generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolSetting {
  id                  String   @id @default(cuid())
  schoolName          String   @default("My School")
  academicYear        String   @default("2024-2025")
  firstPeriodPriority Boolean  @default(true)
  weekDays            String   @default("Sunday,Monday,Tuesday,Wednesday,Thursday,Friday")
  createdAt           DateTime @updatedAt
}

model ScheduleConfig {
  id              String   @id @default(cuid())
  type            String   // LOWER | HIGHER | PRE_PRIMARY | etc.
  periodsPerDay   Int
  periodDuration  Int      // class duration in minutes
  classStartTime  String?  // e.g. "09:00"
  classEndTime    String?  // e.g. "15:30"
  breaks          Json     // [{ type: "SHORT"|"LUNCH", afterPeriod: number, duration: number }]
  assembly        Json?    // { periodIndex: number, duration: number } | null
  createdAt       DateTime @updatedAt

  @@unique([type])
}

model Grade {
  id                   String                @id @default(cuid())
  number               Int?                  @unique
  label                String                @unique
  faculties            Faculty[]
  semesters            Semester[]
  sections             Section[]
  classRooms           ClassRoom[]
  gradeModes           GradeMode[]
  subjectRequirements  SubjectRequirement[]
  teacherGrades        TeacherGrade[]
}

model Semester {
  id        String    @id @default(cuid())
  gradeId  String
  number   Int       // 1-8 for Bachelor, 1-4 for Master
  grade    Grade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  sections Section[]

  @@unique([gradeId, number])
  @@index([gradeId])
}

model Faculty {
  id             String        @id @default(cuid())
  name           String        // e.g. Science, Commerce, BSc CS, MBA (only for grade 11, 12, Bachelor, Master)
  gradeId        String
  grade          Grade         @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  groups         Group[]
  sections       Section[]
  teacherGrades  TeacherGrade[]

  @@unique([gradeId, name])
  @@index([gradeId])
}

model Group {
  id             String        @id @default(cuid())
  name           String        // e.g. Physics, Biology under Science (only for 11, 12, Bachelor, Master)
  facultyId      String
  faculty        Faculty       @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  sections       Section[]
  teacherGrades  TeacherGrade[]

  @@unique([facultyId, name])
  @@index([facultyId])
}

model Section {
  id            String        @id @default(cuid())
  name          String        // A, B, C...
  gradeId       String
  grade         Grade         @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  semesterId    String?
  semester      Semester?     @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  facultyId     String?
  faculty       Faculty?      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  groupId       String?
  group         Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  classRooms    ClassRoom[]
  teacherGrades TeacherGrade[]

  @@index([gradeId, semesterId, facultyId, groupId, name])
}

model ClassRoom {
  id          String   @id @default(cuid())
  gradeId     String
  grade       Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  displayName String   // e.g. "Grade 1-A"
  classTeacher ClassTeacher?
  teacherAssignments TeacherAssignment[]
  subjectRequirements SubjectRequirement[]
  routineSlots RoutineSlot[]

  @@unique([gradeId, sectionId])
  @@index([gradeId])
}

model Subject {
  id               String   @id @default(cuid())
  name             String
  type             String   // THEORY | PRACTICAL | ECA
  requiresResource Boolean  @default(false)
  resourceType     String?
  teacherAssignments TeacherAssignment[]
  subjectRequirements SubjectRequirement[]
  teacherSubjects   TeacherSubject[]
  routineSlots RoutineSlot[]

  @@index([name])
}

model Resource {
  id     String   @id @default(cuid())
  name   String
  type   String
  capacity Int    @default(1)
  routineSlots RoutineSlot[]

  @@index([name])
}

model Teacher {
  id          String   @id @default(cuid())
  name        String
  type        String   // FULL_TIME | PART_TIME
  maxPerWeek  Int
  maxPerDay   Int
  availability TeacherAvailability[]
  classTeachers ClassTeacher[]
  teacherAssignments TeacherAssignment[]
  teacherGrades TeacherGrade[]
  subjects     TeacherSubject[]
  routineSlots RoutineSlot[]

  @@index([name])
}

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model TeacherGrade {
  id        String   @id @default(cuid())
  teacherId String
  gradeId   String
  facultyId String?
  groupId   String?
  sectionId String?
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  faculty   Faculty? @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([gradeId])
}

model TeacherAvailability {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  day          Int      // 0=Sunday .. 5=Friday
  periodIndex  Int
  status       String   // AVAILABLE | BLOCKED | LEAVE

  @@unique([teacherId, day, periodIndex])
}

model ClassTeacher {
  id        String   @id @default(cuid())
  classId   String   @unique
  classRoom ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model TeacherAssignment {
  id        String   @id @default(cuid())
  classId   String
  classRoom ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([classId])
}

model GradeMode {
  id      String @id @default(cuid())
  gradeId String @unique
  grade   Grade  @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  mode    String // GRADE_SYSTEM | SUBJECT_SYSTEM
}

model SubjectRequirement {
  id               String    @id @default(cuid())
  gradeId          String?
  grade            Grade?    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  classId          String?
  classRoom        ClassRoom? @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  periodsPerWeek   Int
  allowDoublePeriod Boolean @default(false)
  maxPerDay        Int?
  avoidConsecutive Boolean  @default(false)

  @@index([gradeId])
  @@index([classId])
}

model RoutineVersion {
  id             String       @id @default(cuid())
  name           String
  status         String       // DRAFT | PUBLISHED | ARCHIVED
  configSnapshot Json?
  createdAt      DateTime     @default(now())
  routineSlots   RoutineSlot[]

  @@index([createdAt])
}

model RoutineSlot {
  id          String        @id @default(cuid())
  versionId   String
  version     RoutineVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  classId     String
  classRoom   ClassRoom     @relation(fields: [classId], references: [id], onDelete: Cascade)
  day         Int           // 0=Sunday .. 5=Friday
  periodIndex Int
  slotType    String        // CLASS | BREAK | LUNCH | ASSEMBLY | FREE
  subjectId   String?
  subject     Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherId   String?
  teacher     Teacher?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  resourceId  String?
  resource    Resource?     @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  isDoublePeriodSecond Boolean @default(false)
  notes       String?

  @@unique([versionId, classId, day, periodIndex])
  @@index([versionId, teacherId, day, periodIndex])
  @@index([versionId, resourceId, day, periodIndex])
}
